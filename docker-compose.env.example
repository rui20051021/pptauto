PPT_MASTER_PORT=8080

# Change this in production.
PPT_UI_SECRET_KEY=replace-with-a-random-long-secret

# Default local persistence inside the Docker volume.
PPT_UI_DATABASE_URL=sqlite:////app/var/ppt_master_ui.db
PPT_UI_STORAGE_BACKEND=local
PPT_UI_MODEL_RUNTIME_CONFIG_PATH=/app/var/model_runtime_config.json

# Use mock for local demo, or openai for an external/OpenAI-compatible model.
PPT_UI_MODEL_PROVIDER=mock
PPT_UI_MODEL_NAME=gpt-4.1-mini
PPT_UI_MODEL_API_KEY=
PPT_UI_MODEL_BASE_URL=

# Keep false unless you explicitly want API requests to block until the job finishes.
PPT_UI_JOB_INLINE=false

# Frontend is proxied by nginx in Docker. Leave this as /api.
VITE_API_BASE_URL=/api
